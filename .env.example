# Rate limiting
RATE_LIMIT_MIN_DELAY=2.0
RATE_LIMIT_MAX_DELAY=8.0
MAX_RETRIES_PER_TIER=3

# Proxy (disabled by default — use --use-proxies CLI flag)
USE_PROXIES=false
PROXY_TIMEOUT=3.0
PROXY_STICKY_COUNT=15
PROXY_MAX_FAILURES=3

# Output
OUTPUT_DIR=output

# Storage
# Leave DATABASE_URL empty for local SQLite. Set it to your Supabase Postgres URL
# so Streamlit and the crawler share the same live database.
DATABASE_URL=
DB_PATH=data/scraper.sqlite
ACQUISITION_DB_PATH=data/acquisition.sqlite

# Scraping limits
MAX_PAGES_PER_CATEGORY=50
CONSECUTIVE_EMPTY_HALT=5

# Browser (Tier 3)
BROWSER_TIMEOUT_MS=30000
BROWSER_HEADLESS=true
